{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["src/cli.ts", "src/web/server.ts"],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": [
    "**/*.d.ts",
    "**/*.test.{ts,tsx}",
    "**/*.spec.{ts,tsx}",
    "**/test/**",
    "**/tests/**",
    "**/__tests__/**",
    "**/node_modules/**",
    "web/**"
  ],
  "ignoreDependencies": [
    "@types/*"
  ]
}
