{
  "name": "ai-sdr-gtm-system",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest",
    "cli": "tsx src/cli.ts",
    "dev:web:live": "zsh -lc 'set -a; source .env; set +a; PORT=8787 tsx src/web/server.ts'",
    "dev:web:mock": "WEB_ADAPTER_MODE=mock PORT=8787 tsx src/web/server.ts",
    "dev:web:validation": "PORT=8888 tsx src/web/server.ts",
    "start:web": "tsx src/web/server.ts",
    "start:web:dist": "node dist/web/server.js",
    "lint": "eslint . --ext .ts",
    "scan:ast-grep": "pnpm --package=@ast-grep/cli dlx ast-grep --config ast-grep.yml scan .",
    "scan:secrets": "gitleaks detect --source . --redact",
    "audit": "pnpm audit --prod --audit-level high"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@supabase/supabase-js": "^2.88.0",
    "commander": "^14.0.2",
    "date-holidays": "^3.26.11",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.19.3",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^9.39.1",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-security-node": "^1.1.4",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "knip": "^5.75.1",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vitest": "^4.0.16"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0",
      "path-to-regexp": "8.4.1"
    },
    "auditConfig": {
      "ignoreCves": [
        "GHSA-r5fr-rjxr-66jc"
      ]
    }
  }
}
